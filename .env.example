API_NINJAS_KEY=
PRIVATE_KEY=
# Polymarket proxy/funder address (profile wallet). Required for SIGNATURE_TYPE 1 or 2.
DEPOSIT_WALLET_ADDRESS=
# 0=MetaMask EOA, 1=Polymarket email/Magic proxy (most users), 2=Gnosis Safe, 3=deposit wallet (SDK broken)
SIGNATURE_TYPE=1
STRATEGY=highest_yes
SHARE_COUNT=10
YES_PRICE_MAX=0.60
# Market ranking price (live CLOB book): midpoint (default), buy_price, best_bid, best_ask, yes_price
SELECTION_PRICE_SOURCE=midpoint
# Order limit price: midpoint (default), buy_price, yes_price, best_bid, best_ask
ORDER_PRICE_SOURCE=midpoint
# Minutes until unfilled orders expire (GTD). Overrides ORDER_EXPIRY_HOURS when set.
ORDER_EXPIRY_MINUTES=25
# Local trading window on the event date (city timezone). Default 14:00–16:00.
# Accepts hour (14), HH:MM (14:00), or HHMM (1400).
TRADING_WINDOW_START_HOUR=14:00
TRADING_WINDOW_END_HOUR=16:00
DRY_RUN=true
DAILY_FETCH_HOUR_UTC=6
# Optional: YYYY-MM-DD for fetch-daily and trade-hourly (default: today)
EVENT_DATE=
# Stop-loss: sell when 10% < (current_mid / avgPrice) * 100 < STOP_LOSS_PCT (default 50)
STOP_LOSS_PCT=50
# Stop-loss floor (default 10). Only sell when value_pct is above this.
STOP_LOSS_PCT_FLOOR=10
# Stop-loss dry-run mode (separate from DRY_RUN used by buy flow)
STOP_LOSS_DRY_RUN=true
# Stop-loss scheduler enabled (AWS schedule is disabled unless explicitly enabled)
STOP_LOSS_SCHEDULE_ENABLED=false
# Stop-loss sell order expiry in minutes (independent from ORDER_EXPIRY_MINUTES for buys)
STOP_LOSS_ORDER_EXPIRY_MINUTES=13
# Optional cap on shares to sell per position (default: sell all)
# STOP_LOSS_SELL_SHARES=
# Event slug/title must contain this marker to be eligible for stop-loss
STOP_LOSS_EVENT_SLUG_MARKER=highest-temperature-in-
# Stop-loss only runs when city local time is at or after this time on the event date
STOP_LOSS_MIN_LOCAL_TIME=16:30
# Sell-win: place tiered limit sell orders during city local 15:00–18:00 window
SOLD_WIN_DRY_RUN=false
SOLD_WIN_SCHEDULE_ENABLED=false
SOLD_WIN_WINDOW_START=15:00
SOLD_WIN_WINDOW_END=18:00
SOLD_WIN_TIER1_START=15:00
SOLD_WIN_TIER1_PRICE=0.91
SOLD_WIN_TIER1_EXPIRE_BEFORE=15:55
SOLD_WIN_TIER2_START=16:00
SOLD_WIN_TIER2_PRICE=0.93
SOLD_WIN_TIER2_EXPIRE_BEFORE=16:55
SOLD_WIN_TIER3_START=17:00
SOLD_WIN_TIER3_PRICE=0.95
SOLD_WIN_TIER3_EXPIRE_BEFORE=17:55
# Event slug/title must contain this marker to be eligible for sell-win
SOLD_WIN_EVENT_SLUG_MARKER=highest-temperature-in-
# Optional cap on shares per sell-win order (default: sell all)
# SOLD_WIN_SELL_SHARES=
# Polymarket Data API base URL
DATA_API_BASE=https://data-api.polymarket.com
