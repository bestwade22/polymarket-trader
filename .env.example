API_NINJAS_KEY=
PRIVATE_KEY=
# Polymarket proxy/funder address (profile wallet). Required for SIGNATURE_TYPE 1 or 2.
DEPOSIT_WALLET_ADDRESS=
# 0=MetaMask EOA, 1=Polymarket email/Magic proxy (most users), 2=Gnosis Safe, 3=deposit wallet (SDK broken)
SIGNATURE_TYPE=1
STRATEGY=highest_yes
SHARE_COUNT=10
YES_PRICE_MAX=0.60
# Market ranking price (live CLOB book): midpoint (default), buy_price, best_bid, best_ask, yes_price
SELECTION_PRICE_SOURCE=midpoint
# Order limit price: midpoint (default), buy_price, yes_price, best_bid, best_ask
ORDER_PRICE_SOURCE=midpoint
# Hours until unfilled orders expire (GTD). Set 0 for no expiry (GTC).
ORDER_EXPIRY_HOURS=2
# Local trading window on the event date (city timezone). Default 12:00–14:00.
# Accepts hour (12), HH:MM (12:30), or HHMM (1230).
TRADING_WINDOW_START_HOUR=12
TRADING_WINDOW_END_HOUR=14
DRY_RUN=true
DAILY_FETCH_HOUR_UTC=6
# Optional: YYYY-MM-DD for fetch-daily and trade-hourly (default: today)
EVENT_DATE=
