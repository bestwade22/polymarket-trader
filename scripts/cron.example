# Polymarket weather trading bot — example crontab entries
# Replace /path/to/polymarket-trader with your install path.

# Daily fetch at 06:00 UTC
0 6 * * * cd /path/to/polymarket-trader && .venv/bin/python -m src.main fetch-daily >> logs/cron.log 2>&1

# Trade check at :05 and :35 each hour (aligns with 14:00 / 15:00 / 16:00 local slots)
5,35 * * * * cd /path/to/polymarket-trader && .venv/bin/python -m src.main trade-hourly >> logs/cron.log 2>&1
